# CiteTong 环境变量配置
# 复制为 .env.local 并填写真实值（.env.local 不会被 git 跟踪）

# ──────────── Auth.js v5 ────────────
# 生成: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-in-production-please-use-openssl-rand"

# Auth.js URL（部署到 Vercel 等会自动设置）
AUTH_URL="http://localhost:3000"

# ──────────── 数据库（生产环境） ────────────
# 当前用 JSON 文件存用户（lib/storage.ts）
# 迁移到 Postgres 时填下面：
# DATABASE_URL="postgresql://user:pass@host.neon.tech/citetong?sslmode=require"

# ──────────── 微信支付 v3 ────────────
# 申请地址：https://pay.weixin.qq.com/
# 拿到后填入：
# WECHAT_PAY_MCH_ID="your-merchant-id"
# WECHAT_PAY_API_V3_KEY="your-32-char-api-v3-key"
# WECHAT_PAY_APP_ID="wx1234567890abcdef"
# WECHAT_PAY_CERT_PATH="/path/to/apiclient_cert.pem"
# WECHAT_PAY_KEY_PATH="/path/to/apiclient_key.pem"

# ──────────── Stripe（海外 / 出海） ────────────
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────────── AI 推理（journal recommender 后续用） ────────────
# 多平台免费额度轮换
DEEPSEEK_API_KEY="sk-..."
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# SILICONFLOW_API_KEY="..."
# GLM_API_KEY="..."
# AGNES_API_KEY="sk-..."

# ──────────── 站点配置 ────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="引用通 / CiteTong"